{
  "name": "mycodediff",
  "private": true,
  "version": "0.1.0",
  "description": "Personal P4 diff desktop app built on @pierre/diffs and @pierre/trees",
  "author": "wangpeng",
  "main": "out/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "bun test",
    "package": "electron-vite build && electron-builder --win --dir",
    "smoke": "bun run scripts/smoke.ts"
  },
  "dependencies": {
    "@pierre/diffs": "1.1.19",
    "@pierre/trees": "1.0.0-beta.3",
    "iconv-lite": "^0.7.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "happy-dom": "^15.11.7",
    "typescript": "^5.9.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.wangpeng.mycodediff",
    "productName": "MyCodeDiff",
    "files": [
      "out/**",
      "package.json"
    ],
    "win": {
      "target": [
        "dir"
      ]
    }
  }
}
